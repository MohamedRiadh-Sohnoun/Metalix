@page "/services"

<PageTitle>Nos services | Metalix</PageTitle>

<div class="services-page u-brand-surface">
    <section class="services-hero" aria-labelledby="services-title">
        <div class="services-hero__grid" aria-hidden="true"></div>
        <div class="services-hero__glow" aria-hidden="true"></div>

        <div class="services-hero__content">
            <p class="services-eyebrow">Nos services</p>
            <h1 id="services-title">Des solutions métalliques claires pour vos chantiers.</h1>
            <p>
                Metalix accompagne les professionnels avec une offre simple: vente de matériaux métalliques,
                conseil technique et préparation rapide des devis.
            </p>
        </div>
    </section>

    <section class="services-grid" aria-label="Services Metalix">
        <article class="service-panel">
            <span>01</span>
            <h2>Vente de matériaux</h2>
            <p>Profilés, tubes, tôles et produits acier adaptés aux besoins du bâtiment et de la fabrication.</p>
        </article>

        <article class="service-panel">
            <span>02</span>
            <h2>Conseil technique</h2>
            <p>Aide au choix des formats, quantités et solutions selon vos contraintes de chantier.</p>
        </article>

        <article class="service-panel">
            <span>03</span>
            <h2>Devis & facturation</h2>
            <p>Demandes organisées, réponse commerciale claire et documents préparés avec précision.</p>
        </article>
    </section>

    <section class="services-strip" aria-label="Secteurs accompagnés">
        <span>Construction</span>
        <span>Rénovation</span>
        <span>Ateliers métalliques</span>
        <span>Projets sur mesure</span>
    </section>

    <section class="services-cta" aria-labelledby="services-cta-title">
        <p class="services-eyebrow">Besoin d'un chiffrage ?</p>
        <h2 id="services-cta-title">Préparez votre demande et recevez un retour sous 24h maximum.</h2>
        <a class="services-button u-focus-ring" href="/request-invoice">Demander un devis</a>
    </section>
</div>
